# PlotIQ — Environment Variables
# Copy this file to .env and fill in all values before running the app.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0

# ── Backend CORS (comma-separated origins) ──────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Database (Supabase PostgreSQL with PostGIS + pgvector) ────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Redis / Celery (Upstash free tier) ────────────────────────────────────────
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Authentication — Clerk ─────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── LLM APIs ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...

# ── File Storage — Cloudflare R2 ──────────────────────────────────────────────
R2_BUCKET=plotiq-documents
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=...
R2_SECRET_KEY=...

# ── Maps ──────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── Frontend (Vite) — prefix with VITE_ ──────────────────────────────────────
# Add these to frontend/.env
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GOOGLE_MAPS_API_KEY=AIza...
